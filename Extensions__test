func TestChainedSyntax(t *testing.T) {

	result := First(From(items).Where("Name", "John").Where("Flag", true))
	result2 := All(From(items).Where("Name", "John").Where("Flag", true))
	result3 := AllOrDefault(From(items).Where("Flag", true))
	result4 := FirstOrDefault(From(items).Where("Name", "John").Where("Flag", 2))

	fmt.Println(*result)
	fmt.Println(*result2)
	fmt.Println(*result3)
	fmt.Println(*result4)

}
